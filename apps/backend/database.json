{
  "dev": {
    "driver": "pg",
    "user": { "ENV": "DB_USER" },
    "password": { "ENV": "DB_PASSWORD" },
    "host": { "ENV": "DB_HOST" },
    "database": { "ENV": "DB_DATABASE" },
    "port": { "ENV": "DB_PORT" }
  },
  "production": {
    "driver": "pg",
    "connectionString": { "ENV": "DATABASE_URL" },
    "ssl": { "rejectUnauthorized": false }
  }
}
